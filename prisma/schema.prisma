generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EntryType {
  NOTE
  LINK
  TASK
  SNIPPET
}

enum EntryStatus {
  INBOX
  ACTIVE
  DONE
  ARCHIVED
}

enum EntrySource {
  MANUAL
  QUICK_CAPTURE
  MEETING
  IMPORT
}

model Workspace {
  id               String            @id @default(uuid())
  name             String
  slug             String            @unique
  color            String
  icon             String?
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  entries          Entry[]
  tags             Tag[]
  meetings         Meeting[]
  environmentLinks EnvironmentLink[]

  @@map("workspaces")
}

model Entry {
  id          String      @id @default(uuid())
  content     String
  type        EntryType   @default(NOTE)
  status      EntryStatus @default(INBOX)
  workspaceId String?     @map("workspace_id")
  assignee    String?
  pinned      Boolean     @default(false)
  metadata    Json?
  source      EntrySource @default(MANUAL)
  meetingId   String?     @map("meeting_id")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  meeting   Meeting?   @relation(fields: [meetingId], references: [id], onDelete: SetNull)
  tags      EntryTag[]

  @@index([workspaceId])
  @@index([status])
  @@index([type])
  @@index([pinned])
  @@index([createdAt])
  @@map("entries")
}

model Tag {
  id          String   @id @default(uuid())
  name        String
  color       String?
  workspaceId String?  @map("workspace_id")
  createdAt   DateTime @default(now()) @map("created_at")

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  entries   EntryTag[]

  @@unique([name, workspaceId])
  @@map("tags")
}

model EntryTag {
  entryId String @map("entry_id")
  tagId   String @map("tag_id")

  entry Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([entryId, tagId])
  @@map("entry_tags")
}

model Meeting {
  id          String    @id @default(uuid())
  name        String
  workspaceId String?   @map("workspace_id")
  startedAt   DateTime  @default(now()) @map("started_at")
  endedAt     DateTime? @map("ended_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  entries   Entry[]

  @@index([endedAt])
  @@index([startedAt])
  @@index([workspaceId])
  @@map("meetings")
}

model EnvironmentLink {
  id          String   @id @default(uuid())
  workspaceId String   @map("workspace_id")
  serviceName String   @map("service_name")
  environment String
  url         String
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, serviceName, environment])
  @@map("environment_links")
}
